# Copy this file to .dev.vars and fill in your values.
# .dev.vars is the Wrangler equivalent of .env for local `wrangler dev`.
# NEVER commit .dev.vars to git.

# Better Auth
# Generate BETTER_AUTH_SECRET with: openssl rand -hex 32
BETTER_AUTH_SECRET="change-me-generate-with-openssl-rand-hex-32"
# The public URL of your local dev worker (wrangler dev default)
BETTER_AUTH_URL="http://localhost:8787"

# Google OAuth 2.0
# 1. Go to console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add Authorised redirect URI: http://localhost:8787/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Google Forms Service Account 
# Go to GCP Console → IAM → Service Accounts → Create → Download JSON key.
# Grant the service account "Forms API" access in the Cloud Console.
# Paste the full JSON as a single line (escape inner quotes with \").
GFORMS_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"leapify@your-project.iam.gserviceaccount.com","client_id":"..."}'

# Google Forms Watch webhook signing secret.
# Generate with: openssl rand -base64 32
# This EXACT value must be provided when calling forms.watches.create.
GFORMS_WEBHOOK_SECRET="your-32-char-random-hex-secret"

# Internal Route Security
# Used to protect /internal/* routes (e.g. gforms webhook) from spoofing.
# Also used as the HMAC signing key for PoW challenge cookies.
# Generate with: openssl rand -base64 32
INTERNAL_API_SECRET="your-32-char-random-hex-secret"

# Proof-of-Work Challenge (Anti-Scraping, Layer 7)
# Leading zero bits required in SHA-256 hash. Higher = harder challenge.
# Default: 4 (~100-500ms solve time). Range: 1-8. Leave empty for default.
POW_DIFFICULTY="4"

# CORS (Standalone Mode Only)
# Define which frontend origins can access this API.
# Leave empty to strictly block all cross-origin requests.
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173,http://localhost:8787"

# Contentful (Headless CMS)
CONTENTFUL_SPACE_ID="your-space-id"
CONTENTFUL_ACCESS_TOKEN="your-content-delivery-api-token"
CONTENTFUL_ENVIRONMENT="master"

# Email Configuration
# At least ONE of SES or Resend is required for email reminders.
# If both are missing, all email functionality is automatically disabled.
EMAIL_FROM_NAME="Leapify"

# Amazon SES (Primary Transactional Email)
# Requires a verified Domain or Email Identity + IAM user credentials.
SES_REGION="ap-southeast-1"
SES_ACCESS_KEY_ID="AKIA..."
SES_SECRET_ACCESS_KEY="your-ses-secret"
SES_FROM_ADDRESS="noreply@yourdomain.com"

# Resend (Primary or Fallback Email)
# - Acts as FALLBACK if SES is configured but fails.
# - Acts as PRIMARY if SES credentials are all missing.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_ADDRESS="noreply@yourdomain.com"
