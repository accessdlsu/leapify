{
  "name": "your-leap-worker",
  "compatibility_date": "2026-04-02",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  // Mode 1: Standalone Worker
  // Point `main` at the pre-built worker bundle.
  // Build it first: npm run build  (or npx tsup)
  "main": "dist/worker.js",
  //
  // Mode 2: npm module (mounted in your own worker)
  // Comment out the line above and point main at your own worker entry, e.g.:
  // "main": "src/worker.ts"   // ← your file that calls createLeapify()

  // Cloudflare D1 (Relational Database) 
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "leapify",
      "database_id": "your-d1-database-id" // from `wrangler d1 create leapify`
    }
  ],

  // Cloudflare KV (Cache & Auth Tokens) 
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "your-kv-namespace-id" // from `wrangler kv namespace create LEAPIFY_KV`
    }
  ],

  // Cloudflare R2 (File Storage — optional) 
  "r2_buckets": [
    {
      "binding": "FILES",
      "bucket_name": "leapify-files"
    }
  ],

  // Cloudflare Queues (Async Jobs — email, audit, snapshots, watch renewals)
  "queues": {
    "producers": [
      {
        "binding": "EMAIL_QUEUE",
        "queue_name": "leapify-email-queue"
      }
    ],
    "consumers": [
      {
        "queue": "leapify-email-queue",
        "max_batch_size": 10,
        "max_batch_timeout": 30,
        "max_retries": 3,
        "dead_letter_queue": "leapify-email-dlq"
      }
    ]
  },

  // Cron Triggers 
  "triggers": {
    "crons": [
      "* * * * *", // batch-release   — publish queued events (every 1 min)
      "*/2 * * * *", // reconcile-slots — D1 vs Google Forms drift fix (every 2 min)
      "0 * * * *", // reminder-emails + lifecycle-check (every hour)
      "0 0 * * *" // renew-watches   — renew expiring Google Forms Watches (daily)
    ]
  }

  // Secrets (set via `wrangler secret put <NAME>`) 
  // Do NOT put secret values here. Use `wrangler secret put` for each:
  //
  // CORS (standalone mode only)
  //  wrangler secret put ALLOWED_ORIGINS
  //  # value: comma-separated list, e.g. "https://yoursite.com,https://www.yoursite.com"
  //  # omit (or set to "") to block all cross-origin requests
  //
  // Core
  //  wrangler secret put FIREBASE_PROJECT_ID
  //  wrangler secret put FIREBASE_WEB_API_KEY
  //  wrangler secret put GFORMS_SERVICE_ACCOUNT_JSON
  //  wrangler secret put GFORMS_WEBHOOK_SECRET
  //  wrangler secret put CONTENTFUL_SPACE_ID
  //  wrangler secret put CONTENTFUL_ACCESS_TOKEN
  //  wrangler secret put CONTENTFUL_ENVIRONMENT
  //  wrangler secret put INTERNAL_API_SECRET
  //
  // Email: Amazon SES (primary — REQUIRED for email)
  //  wrangler secret put SES_REGION            # e.g. us-east-1
  //  wrangler secret put SES_ACCESS_KEY_ID     # IAM user (ses:SendEmail permission)
  //  wrangler secret put SES_SECRET_ACCESS_KEY
  //  wrangler secret put SES_FROM_ADDRESS      # verified SES identity
  //
  // Email: Resend (optional fallback)
  //  wrangler secret put RESEND_API_KEY        # omit to disable fallback entirely
  //  wrangler secret put RESEND_FROM_ADDRESS
}
